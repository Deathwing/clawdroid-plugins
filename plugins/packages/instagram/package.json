{
  "name": "@clawdroid/plugin-instagram",
  "version": "1.0.0",
  "description": "ClawDroid Instagram plugin — TypeScript source",
  "author": "Robert (Deathwing) <deathwing_shadow@hotmail.de>",
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=iife --global-name=__plugin --target=es2020 --outfile=./dist/index.js --footer:js=\"var discoverTools=__plugin.discoverTools;var execute=__plugin.execute;var parseNotification=__plugin.parseNotification;\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
